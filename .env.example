# Trackfi — Environment Variables
# Copy this file to .env and fill in your values.
# The app works fully offline without these — they only enable cloud sync.

# ── Supabase (optional — enables cross-device sync & auth) ──────────────────
# 1. Create a free project at https://supabase.com
# 2. Go to Project Settings → API
# 3. Copy the Project URL and anon/public key below

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ── Web Push Notifications (optional — enables bill/goal reminders) ──────────
# 1. Generate a VAPID key pair: npx web-push generate-vapid-keys
# 2. Paste the public key below (keep the private key on your server only)

VITE_VAPID_PUBLIC_KEY=your-vapid-public-key-here
