# Trackfi — Environment Variables
# Copy this file to .env and fill in your values (never commit .env).
# The app works offline without these; they enable cloud sync, push, and error reporting.

# ── Supabase (optional — cross-device sync & auth) ───────────────────────────
# Dashboard: https://supabase.com → your project → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_public_key

# ── Web Push (optional — bill/goal reminders) ───────────────────────────────
# Generate: npx web-push generate-vapid-keys  (public key only here)
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key

# ── Sentry (optional — production errors) ───────────────────────────────────
# https://sentry.io → project → Client Keys (DSN). Also add the same in Vercel.
# VITE_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx

# ── Vercel (production) ───────────────────────────────────────────────────────
# Dashboard: Project → Settings → Environment Variables
# Add each VITE_* above for Production (and Preview if you want). Redeploy after saving.
