    "test:release": "npm run test && npm run test:e2e"
  },
  "dependencies": {
    "@sentry/react": "^10.46.0",
    "lucide-react": "^0.383.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@vitejs/plugin-react": "^4.2.1",
    "jsdom": "^29.0.1",
    "sharp": "^0.34.5",
    "vite": "^5.4.21",
    "vitest": "^4.1.2"
  }
}
